# Discord Developer Portal -> Bot -> Token
DISCORD_TOKEN=put-your-discord-bot-token-here

# OpenRouter account -> Keys
OPENROUTER_API_KEY=put-your-openrouter-api-key-here

# The requested model. Override only if OpenRouter changes the model id.
OPENROUTER_MODEL=openai/gpt-oss-120b

# Optional attribution headers shown in OpenRouter dashboards.
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_APP_TITLE=PaperclipMaxxer

# Optional tuning.
DATABASE_PATH=paperclipmaxxer.sqlite3
MAX_RECENT_MESSAGES=18
MAX_HISTORY_LOOKBACK=35
CONVERSATION_TTL_SECONDS=900

